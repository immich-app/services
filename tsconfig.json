{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["@types/node"],
    "composite": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "src/**/*.ts",
    "apps/*/src/**/*.ts",
    "apps/*/worker-configuration.d.ts",
    "*.config.ts",
    "apps/*/*.config.ts"
  ],
  "exclude": ["node_modules", "**/dist", "**/.wrangler"]
}
